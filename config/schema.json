{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Model Safety Evaluation Config",
  "type": "object",
  "required": ["target", "judge"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Evaluation name"
    },
    "target": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": {"type": "string"},
        "method": {"type": "string", "default": "POST"},
        "headers": {"type": "object", "additionalProperties": {"type": "string"}},
        "cookies": {"type": "object", "additionalProperties": {"type": "string"}},
        "body_template": {"type": "object"},
        "injection_point": {"type": "string", "default": "$.messages[-1].content"},
        "response_type": {"type": "string", "enum": ["sse", "json"], "default": "sse"}
      }
    },
    "judge": {
      "type": "object",
      "required": ["base_url", "api_key", "model"],
      "properties": {
        "base_url": {"type": "string"},
        "api_key": {"type": "string"},
        "model": {"type": "string"},
        "temperature": {"type": "number", "default": 0.0},
        "enable_local_fallback": {"type": "boolean", "default": true}
      }
    },
    "evaluation": {
      "type": "object",
      "properties": {
        "dimensions": {
          "type": "array",
          "items": {"type": "string", "enum": ["prompt_injection", "tool_security"]}
        },
        "attack_techniques": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["text_transform", "emoji", "resource_consumption", "input_perturbation",
                     "garbled", "char_mapping", "splitter_decoder", "ai_rewrite", "ascii_smuggling",
                     "tool_discovery", "tool_abuse_chained", "many_shot", "multilingual"]
          }
        },
        "max_rounds_per_attack": {"type": "integer", "default": 5},
        "dynamic_payloads": {"type": "boolean", "default": true},
        "payload_mutators": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["base64", "rot13", "zero_width", "roleplay_wrapper", "markdown_link"]
          },
          "default": ["base64", "roleplay_wrapper"]
        },
        "max_mutations_per_vector": {"type": "integer", "default": 1},
        "detectors": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["refusal", "sensitive_leak", "tool_boundary"]
          },
          "default": ["sensitive_leak", "tool_boundary"]
        },
        "enable_verification": {"type": "boolean", "default": true},
        "tool_security": {
          "type": "object",
          "properties": {
            "active_probing_strategies": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["direct_inquiry", "indirect_guidance", "role_playing",
                         "capability_probing", "context_followup"]
              }
            },
            "vuln_test_types": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["parameter_tampering", "privilege_escalation",
                         "chain_calling", "indirect_invocation", "information_leakage"]
              }
            },
            "capability_test_types": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["command_execution", "network_ssrf", "file_boundary", "data_exfiltration_chain"]
              }
            },
            "ssrf_canary_url": {"type": "string", "default": "https://example.com/model-safety-eval-canary"},
            "environment_policy": {
              "type": "object",
              "properties": {
                "sandbox_expected": {"type": "boolean", "default": true},
                "allow_command_execution": {"type": "boolean", "default": false},
                "allow_external_network": {"type": "boolean", "default": false},
                "allowed_domains": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "allowed_paths": {
                  "type": "array",
                  "items": {"type": "string"}
                }
              }
            },
            "max_rounds_per_probe": {"type": "integer", "default": 3},
            "max_rounds_per_exploit": {"type": "integer", "default": 5}
          }
        }
      }
    }
  }
}
